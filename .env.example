# Variáveis de ambiente - NÃO commitar .env com valores reais
# Copiar para .env e preencher (ou configurar no Render Dashboard)

# URL do backend - SOMENTE no servidor (server.js), nunca no código cliente
# Usado pelo proxy em produção. Configurar no Render Dashboard do frontend.
BACKEND_API_URL=https://SEU-BACKEND.onrender.com

# Para desenvolvimento local - frontend chama backend diretamente
# (O proxy não é usado em dev com Vite)
VITE_API_URL=http://localhost:3001/api/sociais
