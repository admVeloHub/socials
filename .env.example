# Variáveis de ambiente - NÃO commitar .env com valores reais
# Configurar no Render Dashboard do frontend Natralha (tabulações)

# NATRALHA - Backend de tabulações (rotas /api/sociais)
# Frontend como Static Site: use VITE_API_URL com URL completa
VITE_API_URL=https://[BACKEND-NATRALHA].onrender.com/api/sociais

# Frontend como Web Service (com proxy): use BACKEND_API_URL
BACKEND_API_URL=https://[BACKEND-NATRALHA].onrender.com

# Desenvolvimento local:
VITE_API_URL=http://localhost:3001/api/sociais
